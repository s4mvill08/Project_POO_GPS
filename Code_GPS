import random
import time
import tabulate

class Region:
    def __init__(self, nombre, poblacion, nivel_medico):
        self.nombre = nombre
        self.__poblacion_total = poblacion
        self.__infectados = 0
        self.__fallecidos = 0
        self.__nivel_medico = nivel_medico 
        self.__fronteras_abiertas = True

    def obtener_infectados(self): 
        return self.__infectados
        
    def obtener_fallecidos(self): 
        return self.__fallecidos
        
    def obtener_poblacion_viva(self): 
        return self.__poblacion_total - self.__fallecidos
    
    def obtener_estado_frontera(self):
        return self.__fronteras_abiertas

    def cerrar_frontera(self):
        self.__fronteras_abiertas = False

    def iniciar_contagio(self):
        if self.__infectados == 0:
            self.__infectados = 100

    def simular_dia(self, infectividad, letalidad):
        if self.__infectados > 0:
            resistencia = self.__nivel_medico * 0.05
            tasa_real = infectividad - resistencia
            
            nuevos = int(self.__infectados * tasa_real)
            self.__infectados = self.__infectados + nuevos
            
            if self.__infectados > self.obtener_poblacion_viva():
                self.__infectados = self.obtener_poblacion_viva()

            muertos = int(self.__infectados * letalidad)
            self.__fallecidos = self.__fallecidos + muertos
            self.__infectados = self.__infectados - muertos

class Jugador:
    def __init__(self, rol):
        self.rol = rol
        self.puntos = 0 
        self.infectividad = 0.30
        self.letalidad = 0.02

    def usar_puntos(self, mundo):
        print()
        if self.rol == "Patogeno":
            if self.puntos >= 30:
                self.infectividad = self.infectividad + 0.10
                self.puntos = self.puntos - 30
                print(">>> MEJORA: El virus ahora es mas contagioso.")
            else:
                print(">>> Error: No tienes suficiente ADN.")
        else:
            if self.puntos >= 50:
                for r in mundo.regiones:
                    r.cerrar_frontera()
                self.puntos = self.puntos - 50
                print(">>> ACCION: Se han cerrado todas las fronteras.")
            else:
                print(">>> Error: No tienes presupuesto.")

